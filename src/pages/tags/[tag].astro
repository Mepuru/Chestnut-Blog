---
import BaseLayout from '@kurikana/astro-theme/layouts/BaseLayout.astro';
import PostCard from '@kurikana/astro-theme/components/blog/PostCard.astro';
import { siteConfig } from '../../config/site';
import { themes, defaultTheme } from '@kurikana/astro-theme/utils/themes';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../../utils/content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allTags = posts.flatMap((p) => p.data.tags);
  const uniqueTags = [...new Set(allTags)];

  return uniqueTags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { title, description, nav, author, footer } = siteConfig;

const { tag } = Astro.props;

const publishedPosts = await getPublishedPosts();
const posts = publishedPosts.filter((p) => p.data.tags.includes(tag));

// 全局标签（给侧边栏）
const allTags = publishedPosts.flatMap((p) => p.data.tags);
const tagCountMap = allTags.reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const sortedTags = Object.entries(tagCountMap)
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));

const sidebarData = {
  avatar: siteConfig.avatar,
  author: siteConfig.author,
  bio: siteConfig.bio,
  postsCount: publishedPosts.length,
  tags: sortedTags,
  tagCount: sortedTags.length,
  githubUrl: siteConfig.social.github,
};
---

<BaseLayout
  siteTitle={title}
  siteDescription={description}
  nav={nav}
  themes={themes}
  defaultTheme={defaultTheme}
  author={author}
  icp={footer.icp}
  icpUrl={footer.icpUrl}
  title={`${tag} - 栗かな的博客`}
  sidebar={true}
  sidebarData={sidebarData}
>
  <a href="/blog" class="back-link">&larr; 所有文章</a>
  <h1 class="page-title">标签：{tag}</h1>
  <p class="tag-desc">共 {posts.length} 篇文章</p>
  <div class="post-grid">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        slug={post.id}
        tags={post.data.tags}
      />
    ))}
  </div>
</BaseLayout>

<style>
  .tag-desc {
    color: var(--muted);
    margin-bottom: 1.5rem;
  }
</style>