---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonSidebar from '../../components/lessons/LessonSidebar.astro';
import { getCollection } from 'astro:content';

const lessons = (await getCollection('lessons'))
  .filter((lesson) => !lesson.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="日语教案" description="每周系统的日语学习">
  <div class="lessons-page">
    <LessonSidebar />

    <main class="lessons-main">
      <div class="lessons-header">
        <h1 class="lessons-title">日语教案</h1>
        <p class="lessons-description">每周系统的日语学习</p>
      </div>

      <div class="lessons-list">
        {lessons.map((lesson) => {
          const dateStr = lesson.data.date.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
          });

          return (
            <a href={`/lessons/${lesson.id}`} class="lesson-card">
              <div class="lesson-meta">
                <time class="lesson-date">{dateStr}</time>
              </div>
              <h2 class="lesson-card-title">{lesson.data.title}</h2>
            </a>
          );
        })}
      </div>

      {lessons.length === 0 && (
        <div class="lessons-empty">
          <p>暂无教案内容</p>
        </div>
      )}
    </main>
  </div>
</BaseLayout>

<style>
  .lessons-page {
    display: flex;
    gap: 2rem;
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .lessons-main {
    flex: 1;
    min-width: 0;
  }

  .lessons-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .lessons-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 0.5rem 0;
  }

  .lessons-description {
    font-size: 0.95rem;
    color: var(--muted);
    margin: 0;
  }

  .lessons-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lesson-card {
    display: block;
    padding: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .lesson-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-light);
  }

  .lesson-meta {
    margin-bottom: 0.5rem;
  }

  .lesson-date {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .lesson-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
  }

  .lessons-empty {
    text-align: center;
    padding: 4rem 0;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .lessons-page {
      flex-direction: column;
      padding: 1rem;
    }
  }
</style>
