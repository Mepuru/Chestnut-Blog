---
import BaseLayout from './BaseLayout.astro';
import LessonSidebar from '../components/lessons/LessonSidebar.astro';
import TOC from '../components/shared/TOC.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  currentSlug?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { title, description, date, currentSlug, headings = [] } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout title={`${title} - 日语教案`} description={description}>
  <div class="lessons-page">
    <LessonSidebar currentSlug={currentSlug} />

    <main class="lessons-main">
      <article class="lesson">
        <header class="lesson-header">
          <div class="lesson-meta">
            <time class="lesson-date">{dateStr}</time>
          </div>
          <h1 class="lesson-title">{title}</h1>
        </header>
        <div class="lesson-content prose">
          <slot />
        </div>
      </article>
    </main>

    {headings.length > 0 && <TOC headings={headings} />}
  </div>
</BaseLayout>

<style>
  .lessons-page {
    display: grid;
    grid-template-columns: 260px 1fr 220px;
    min-height: calc(100vh - 64px);
  }

  .lessons-main {
    min-width: 0;
    display: flex;
    justify-content: center;
    padding: 2rem 3rem;
  }

  .lesson {
    width: 100%;
    max-width: 750px;
  }

  .lesson-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .lesson-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .lesson-title {
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 0;
  }

  .lesson-content {
    line-height: 1.9;
  }

  /* 小屏幕时隐藏 TOC */
  @media (max-width: 1200px) {
    .lessons-page {
      grid-template-columns: 260px 1fr;
    }
  }

  /* 手机端隐藏侧边栏 */
  @media (max-width: 768px) {
    .lessons-page {
      grid-template-columns: 1fr;
    }

    .lessons-main {
      padding: 1.5rem 1rem;
    }
  }
</style>
