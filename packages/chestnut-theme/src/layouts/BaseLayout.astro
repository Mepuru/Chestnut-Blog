---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import Sidebar from '../components/shared/Sidebar.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface SidebarTag {
  name: string;
  count: number;
}

interface NavItem {
  href: string;
  label: string;
}

interface ThemeItem {
  id: string;
  name: string;
}

interface Props {
  // Site-wide config
  siteTitle: string;
  siteDescription: string;
  nav: NavItem[];
  themes: ThemeItem[];
  defaultTheme: string;
  // Footer
  author: string;
  icp?: string;
  icpUrl?: string;
  // Page-level
  title?: string;
  description?: string;
  // Sidebar (optional)
  sidebar?: boolean;
  sidebarData?: {
    avatar: string;
    author: string;
    bio: string;
    postsCount: number;
    tags: SidebarTag[];
    tagCount: number;
    githubUrl?: string;
  };
}

const {
  siteTitle, siteDescription, nav, themes, defaultTheme,
  author, icp, icpUrl,
  title = siteTitle, description = siteDescription,
  sidebar = false, sidebarData,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem('theme') || defaultTheme;
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <div class="print-meta" style="display:none">{siteTitle} | {Astro.url.href}</div>
    <Header siteTitle={siteTitle} nav={nav} themes={themes} />
    <div class:list={['layout-wrapper', { wide: !sidebar }]}>
      <main class="main-content">
        <slot />
      </main>
      {sidebar && sidebarData && (
        <Sidebar
          avatar={sidebarData.avatar}
          author={sidebarData.author}
          bio={sidebarData.bio}
          postsCount={sidebarData.postsCount}
          tags={sidebarData.tags}
          tagCount={sidebarData.tagCount}
          githubUrl={sidebarData.githubUrl}
        />
      )}
    </div>
    <Footer {author} {icp} {icpUrl} />
    <Search />
    <script>
      document.addEventListener('astro:after-swap', () => {
        const theme = localStorage.getItem('theme');
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
        }
      });

      window.addEventListener('beforeprint', () => {
        document.querySelectorAll('details').forEach(el => el.setAttribute('open', ''));
      });
      window.addEventListener('afterprint', () => {
        document.querySelectorAll('details').forEach(el => el.removeAttribute('open'));
      });
    </script>
  </body>
</html>