---
/**
 * Mermaid 图表渲染组件
 *
 * Expressive Code 处理代码块 UI（语言标签、复制按钮），
 * 本组件只负责将 ```mermaid 代码块渲染为 SVG 图表，
 * 并提供 图表/源码 切换。
 */
---

<script>
  import mermaid from 'mermaid';

  let ready = false;

  function render() {
    const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
    if (!blocks.length) return;

    if (!ready) {
      mermaid.initialize({ startOnLoad: false, theme: 'default' });
      ready = true;
    }

    blocks.forEach((pre) => {
      if (pre.dataset.mermaidProcessed) return;
      pre.dataset.mermaidProcessed = 'true';

      const rawText = pre.textContent ?? '';
      const container = document.createElement('div');
      container.className = 'mermaid-container';

      const toggleBtn = document.createElement('button');
      toggleBtn.className = 'mermaid-toggle';
      toggleBtn.textContent = '查看图表';
      toggleBtn.type = 'button';
      container.appendChild(toggleBtn);

      const diagramDiv = document.createElement('div');
      diagramDiv.className = 'mermaid-render';
      diagramDiv.textContent = rawText.trim();
      diagramDiv.style.display = 'none';
      container.appendChild(diagramDiv);

      pre.parentNode?.insertBefore(container, pre);
      container.appendChild(pre);

      toggleBtn.addEventListener('click', () => {
        const showingCode = diagramDiv.style.display === 'none';
        pre.style.display = showingCode ? 'none' : '';
        diagramDiv.style.display = showingCode ? '' : 'none';
        toggleBtn.textContent = showingCode ? '查看源码' : '查看图表';

        if (showingCode) {
          try {
            mermaid.run({ querySelector: '.mermaid-render' });
          } catch { /* 静默 */ }
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
  document.addEventListener('astro:after-swap', render);
</script>

<style>
  .mermaid-container {
    position: relative;
  }

  .mermaid-toggle {
    position: absolute;
    top: 0.5rem;
    right: 3rem;
    z-index: 1;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--card-bg);
    color: var(--fg);
    cursor: pointer;
    transition: all 0.2s ease;
    line-height: 1.4;
    opacity: 0.8;
  }

  .mermaid-toggle:hover {
    opacity: 1;
    background: var(--accent-light);
    border-color: var(--accent);
    color: var(--accent);
  }

  .mermaid-render {
    padding: 1.5rem 1rem;
    display: flex;
    justify-content: center;
    overflow-x: auto;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .mermaid-render svg {
    max-width: 100%;
    height: auto;
  }
</style>
